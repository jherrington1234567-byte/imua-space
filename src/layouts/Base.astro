---
import '../styles/tokens.css';
import site from '../data/site.json';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Joshua Herrington — IMUA',
  description = 'Guarantees, not guesses. A check, not a maybe — guaranteed protection that pays when it matters most. Court of the Table advisor, compulsive builder, and writer.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon-64.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icon-180.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#2c1f0e" />

    <!-- Open Graph / share -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://imua.space/" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <nav>
      <div class="wrap">
        <a class="brand" href="/#top" aria-label="Joshua Herrington — home">
          <!-- JH "Sisyphus pushing the arrow" mark -->
          <img class="brand-mark" src="/brand/jh-logo.png" alt="JH" width="44" height="26" />
          <span>{site.name}</span>
        </a>
        <div class="navlinks">
          {site.nav.map((item) => <a href={item.href}>{item.label}</a>)}
        </div>
      </div>
    </nav>

    <slot />

    <footer>
      <div class="wrap">
        <a class="footer-logo" href="/book/" aria-label="IMUA — The Values Project">
          <img src="/brand/imua-logo.png" alt="IMUA" width="220" height="91" />
        </a>
        <div class="project-name">The Values Project</div>
        <div class="values">
          {site.values.map((v, i) => (
            <>{i > 0 && ' · '}<span>{v}</span></>
          ))}
        </div>
        <nav class="footer-links">
          <a href="/about/#press">Press &amp; Media</a>
          <a href={site.podcast.links[0].href} target="_blank" rel="noopener">NAIFA Podcast</a>
          <a href={site.linkedinUrl} target="_blank" rel="noopener">LinkedIn</a>
          <a href={site.substackUrl} target="_blank" rel="noopener">Substack</a>
        </nav>
        <small>© 2026 {site.name} · {site.domain} · {site.tagline}</small>
        <p class="disclaimer">
          For financial professional use only. Educational and informational — not financial, insurance,
          tax, or legal advice, and not an offer or solicitation. No promise or guarantee of any result.
          Any product "guarantees" are the obligations of the issuing carrier, subject to its claims-paying
          ability; tools use synthetic demo data and must be confirmed with the carrier before any sale.
          <a href="/disclaimer">Full disclaimer →</a>
        </p>
      </div>
    </footer>

    <style>
      /* spine: nav + footer brown (reserved colour) */
      nav {
        position: sticky; top: 0; z-index: 20;
        background: var(--brown); border-bottom: 1px solid #4a3a22;
      }
      nav .wrap {
        display: flex; align-items: center; justify-content: space-between; height: 62px;
      }
      .brand {
        display: flex; align-items: center; gap: 11px;
        font-family: var(--serif); font-size: 18px; color: var(--cream);
        text-decoration: none;
      }
      .brand-mark { height: 26px; width: auto; display: block; }
      .navlinks { display: flex; gap: 22px; font-size: 14px; color: #cfc2ad; }
      .navlinks a { text-decoration: none; }
      .navlinks a:hover { color: #fff; }

      footer {
        background: var(--brown); color: #cdbfa9; padding: 40px 0; text-align: center;
      }
      .footer-logo { display: inline-block; }
      .footer-logo img {
        width: 220px; max-width: 70vw; height: auto; display: block;
        opacity: .96; transition: opacity .2s;
      }
      .footer-logo:hover img { opacity: 1; }
      .project-name {
        font-family: var(--serif); font-size: 13px; letter-spacing: 3px;
        text-transform: uppercase; color: var(--ember); margin-top: 10px;
      }
      .values {
        font-family: var(--serif); font-size: 18px; color: var(--cream); letter-spacing: 1px;
        margin-top: 14px;
      }
      .values span { color: var(--ember); }
      .footer-links {
        margin-top: 18px; display: flex; flex-wrap: wrap; justify-content: center;
        gap: 8px 18px; font-size: 13px;
      }
      .footer-links a { color: #d9a06a; text-decoration: none; }
      .footer-links a:hover { color: #fff; text-decoration: underline; }
      footer small { display: block; margin-top: 16px; font-size: 12px; }
      .disclaimer {
        max-width: 760px; margin: 16px auto 0; font-size: 11px; line-height: 1.6;
        color: #a99a82;
      }
      .disclaimer a { color: #d9a06a; text-decoration: none; white-space: nowrap; }
      .disclaimer a:hover { text-decoration: underline; }

      @media (max-width: 640px) {
        .navlinks { display: none; }
      }
    </style>
  </body>
</html>
