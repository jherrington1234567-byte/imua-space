---
/* ============================================================
   THE WORK — what Joshua has built + the skillset behind it.
   Descriptive only: the shape of the work and the capability,
   not live demos of any specific tool. Edit the cards below.
   ============================================================ */
const CRAFT = [
  {
    accent: 'p',
    tag: 'Planning engines',
    title: 'Product & planning systems',
    body: "Private-placement planning engines that teach the product, model any scenario, map revenue to every party, carry the operational flow, and monitor compliance end to end — built by hand, far past a tabular illustration.",
  },
  {
    accent: 'y',
    tag: 'Underwriting',
    title: 'Cross-border underwriting',
    body: "Routers for the cases most advisors call “uninsurable” — mapping a client’s citizenship, residency, and U.S. ties to the carriers who will actually write them, with the field resources to close.",
  },
  {
    accent: 'b',
    tag: 'Economics',
    title: 'Deal & partnership models',
    body: "Interactive economic models — pull the levers on architecture, earnout, market, and scale and watch gross revenue, net, and unit economics move in real time. The math made legible the moment an assumption changes.",
  },
  {
    accent: 'c',
    tag: 'Leadership',
    title: 'Sales-leadership OS',
    body: "A sales-leadership operating system: positioning that flexes to the advisor, one advisor plugged into the whole platform. The systems I design, coach, and run — recruiting, pipeline, and process as one engine.",
  },
  {
    accent: 'b',
    tag: 'Data',
    title: 'Growth dashboards',
    body: "Interactive boards for distribution growth by type and channel — the kind of data viz I build to think, and to show a team where revenue actually comes from.",
  },
  {
    accent: 'p',
    tag: 'Enablement',
    title: 'Training & enablement',
    body: "PPLI/PPVA primers and partner decks that bring RIAs and broker-dealers up to speed fast — the education layer that makes a complex product usable in the field.",
  },
];

const SKILLS = [
  'Next.js', 'Prisma', 'TypeScript', 'Full-stack build', 'Data visualization',
  'Financial modeling', 'PPLI / PPVA', 'Cross-border underwriting',
  'Revenue architecture', 'Sales leadership', 'Compliance',
];
---
<section class="work" id="work">
  <div class="wrap">
    <span class="kicker">The work</span>
    <h2>What I've built</h2>
    <p class="lead">Not screenshots of ideas — working systems, designed and built by hand. Here's the shape of what I make and the skillset behind it.</p>

    <div class="grid3">
      {CRAFT.map((c) => (
        <div class={`card k-${c.accent}`}>
          <span class="tag">{c.tag}</span>
          <h3>{c.title}</h3>
          <p>{c.body}</p>
        </div>
      ))}
    </div>

    <div class="skills" aria-label="Skillset">
      {SKILLS.map((s) => <span class="skill">{s}</span>)}
    </div>
  </div>
</section>

<style>
  .work { background: var(--blue-50); }
  .work .kicker { color: var(--blue-s); }
  .work h2 { margin-top: 12px; font-size: 29px; }
  .grid3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; margin-top: 30px; }
  .card {
    background: #fff; border: 1px solid var(--line); border-radius: var(--radius); padding: 20px;
  }
  .card .tag { font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase; font-weight: 600; }
  .card.k-p .tag { color: var(--pink-s); }
  .card.k-b .tag { color: var(--blue-s); }
  .card.k-y .tag { color: var(--yellow-s); }
  .card.k-c .tag { color: var(--coral-s); }
  .card h3 { font-size: 18px; margin: 8px 0 6px; }
  .card p { font-size: 14px; color: var(--muted); }

  .skills { display: flex; flex-wrap: wrap; gap: 9px; margin-top: 28px; }
  .skill {
    font-size: 12.5px; padding: 6px 13px; border-radius: 999px; font-weight: 500;
    background: #fff; border: 1px solid var(--line); color: var(--muted);
  }

  @media (max-width: 820px) { .grid3 { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .grid3 { grid-template-columns: 1fr; } }
</style>
