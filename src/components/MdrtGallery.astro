---
import mdrt from '../data/mdrt.json';
const { images } = mdrt;
// Until the 173 stills are converted (npm run images), show a placeholder grid.
const placeholders = images.length === 0 ? Array.from({ length: 18 }) : [];

// Build filter pills from the distinct capture dates present in the manifest.
// (The set spans many days, so a fixed "Day 1/Day 2" model doesn't fit — filter by date.)
const fmt = (iso: string) =>
  new Date(iso + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
const dates = [...new Set(images.map((i) => i.date).filter(Boolean))].sort();
const filters = [{ key: 'All', label: `All ${images.length}` }, ...dates.map((d) => ({ key: d, label: fmt(d) }))];
---
<section class="gallery" id="gallery">
  <div class="wrap">
    <span class="kicker">Signature feature</span>
    <h2>MDRT — find yourself</h2>
    <p class="lead">Frames from the floor. Filter by the day it was taken, find the photo you're in, and take it with you.</p>

    <div class="filterrow" role="tablist" aria-label="Filter MDRT photos">
      {filters.map((f, i) => (
        <button class={`fpill${i === 0 ? ' active' : ''}`} data-filter={f.key}>{f.label}</button>
      ))}
    </div>

    {images.length > 0 ? (
      <div class="mgrid" id="mgrid">
        {images.map((im, i) => (
          <button class="t" data-date={im.date} data-full={im.full} data-index={i} aria-label="Open photo">
            <img src={im.thumb} alt={im.alt ?? 'MDRT 2026'} loading="lazy" width="300" height="300" />
          </button>
        ))}
      </div>
    ) : (
      <>
        <div class="mgrid placeholder">
          {placeholders.map(() => <div class="t ph">photo</div>)}
        </div>
        <p class="hint">Placeholder grid — run <code>npm run images</code> to convert the 173 stills from HEIC and populate the gallery.</p>
      </>
    )}
  </div>

  <!-- lightbox -->
  <div class="lightbox" id="lightbox" hidden>
    <button class="lb-close" aria-label="Close">×</button>
    <button class="lb-prev" aria-label="Previous">‹</button>
    <img src="" alt="" id="lb-img" />
    <button class="lb-next" aria-label="Next">›</button>
  </div>
</section>

<style>
  .gallery { background: var(--pink-50); }
  .gallery .kicker { color: var(--pink-s); }
  .gallery h2 { margin-top: 12px; font-size: 29px; }
  .filterrow { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 20px; }
  .fpill {
    font-size: 12px; background: #fff; border: 1px solid #efd7e1; color: var(--pink-s);
    border-radius: 999px; padding: 5px 12px; cursor: pointer;
  }
  .fpill.active { background: var(--pink-s); color: #fff; border-color: var(--pink-s); }

  .mgrid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 8px; margin-top: 22px; }
  .mgrid .t {
    aspect-ratio: 1; border-radius: 10px; overflow: hidden; border: none; padding: 0;
    background: #f6d9e4; cursor: pointer;
  }
  .mgrid .t img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .mgrid .t.ph {
    display: flex; align-items: center; justify-content: center;
    color: #c98ba6; font-size: 11px; cursor: default;
  }
  .hint { font-size: 12px; color: #bd86a0; margin-top: 14px; }
  .hint code { background: #fff; padding: 1px 6px; border-radius: 5px; }

  .lightbox {
    position: fixed; inset: 0; z-index: 50; background: rgba(20, 16, 10, .9);
    display: flex; align-items: center; justify-content: center;
  }
  .lightbox[hidden] { display: none; }
  .lightbox img { max-width: 88vw; max-height: 86vh; border-radius: 8px; }
  .lightbox button {
    position: absolute; background: rgba(255, 255, 255, .12); color: #fff; border: none;
    cursor: pointer; font-size: 28px; width: 48px; height: 48px; border-radius: 50%;
  }
  .lb-close { top: 20px; right: 24px; }
  .lb-prev { left: 18px; }
  .lb-next { right: 18px; }

  @media (max-width: 820px) { .mgrid { grid-template-columns: repeat(4, 1fr); } }
</style>

<script>
  // Filter pills
  const pills = document.querySelectorAll<HTMLButtonElement>('.fpill');
  const tiles = () => Array.from(document.querySelectorAll<HTMLElement>('#mgrid .t'));
  pills.forEach((p) =>
    p.addEventListener('click', () => {
      pills.forEach((x) => x.classList.remove('active'));
      p.classList.add('active');
      const f = p.dataset.filter;
      tiles().forEach((t) => {
        const show = f === 'All' || t.dataset.date === f;
        t.style.display = show ? '' : 'none';
      });
    }),
  );

  // Lightbox
  const lb = document.getElementById('lightbox') as HTMLElement | null;
  const lbImg = document.getElementById('lb-img') as HTMLImageElement | null;
  if (lb && lbImg) {
    const visible = () => tiles().filter((t) => t.style.display !== 'none');
    let idx = 0;
    const open = (i: number) => {
      const list = visible();
      idx = (i + list.length) % list.length;
      const full = list[idx]?.dataset.full;
      if (full) { lbImg.src = full; lb.hidden = false; }
    };
    document.getElementById('mgrid')?.addEventListener('click', (e) => {
      const t = (e.target as HTMLElement).closest('.t') as HTMLElement | null;
      if (t) open(visible().indexOf(t));
    });
    lb.querySelector('.lb-close')?.addEventListener('click', () => (lb.hidden = true));
    lb.querySelector('.lb-next')?.addEventListener('click', () => open(idx + 1));
    lb.querySelector('.lb-prev')?.addEventListener('click', () => open(idx - 1));
    lb.addEventListener('click', (e) => { if (e.target === lb) lb.hidden = true; });
    document.addEventListener('keydown', (e) => {
      if (lb.hidden) return;
      if (e.key === 'Escape') lb.hidden = true;
      if (e.key === 'ArrowRight') open(idx + 1);
      if (e.key === 'ArrowLeft') open(idx - 1);
    });
  }
</script>
