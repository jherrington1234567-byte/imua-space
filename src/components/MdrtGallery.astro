---
import Gallery from './Gallery.astro';
import mdrt from '../data/mdrt.json';

const fmt = (iso: string) =>
  new Date(iso + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric' });

const images = mdrt.images.map((im) => ({
  thumb: im.thumb,
  full: im.full,
  caption: im.date ? `MDRT · ${fmt(im.date)}` : 'MDRT 2026',
  key: im.date,
}));

const dates = [...new Set(mdrt.images.map((i) => i.date).filter(Boolean))].sort();
const filters = [
  { key: 'All', label: `All ${images.length}` },
  ...dates.map((d) => ({ key: d, label: fmt(d) })),
];
---
<section class="gallery" id="gallery">
  <div class="wrap">
    <span class="kicker">Signature feature</span>
    <h2>MDRT — find yourself</h2>
    <p class="lead">Frames from the floor. Filter by the day it was taken, find the photo you're in, and take it with you. Twenty to start — load more to keep digging.</p>

    {images.length > 0 ? (
      <Gallery images={images} initial={20} cols={6} aspect="1" accent="pink" filters={filters} />
    ) : (
      <p class="hint">Run <code>npm run images -- --mdrt &lt;dir&gt;</code> to convert the stills and populate the gallery.</p>
    )}
  </div>
</section>

<style>
  .gallery { background: var(--pink-50); }
  .gallery .kicker { color: var(--pink-s); }
  .gallery h2 { margin-top: 12px; font-size: 29px; }
  .hint { font-size: 12px; color: #bd86a0; margin-top: 14px; }
  .hint code { background: #fff; padding: 1px 6px; border-radius: 5px; }
</style>
