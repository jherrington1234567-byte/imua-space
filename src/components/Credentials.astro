---
import site from '../data/site.json';
---
<section class="creds">
  <div class="wrap">
    <span class="kicker">Credentials &amp; speaking</span>
    <h2>The record</h2>
    <ul>
      {site.credentials.map((c) => <li>{c}</li>)}
    </ul>
  </div>
</section>

<style>
  .creds .kicker { color: var(--ember); }
  .creds h2 { margin-top: 12px; font-size: 29px; }
  .creds ul {
    list-style: none; margin-top: 24px;
    display: grid; grid-template-columns: 1fr 1fr; gap: 12px 30px;
  }
  .creds li { font-size: 15px; padding-left: 22px; position: relative; }
  .creds li::before { content: "›"; position: absolute; left: 0; color: var(--ember); font-weight: 700; }

  @media (max-width: 820px) { .creds ul { grid-template-columns: 1fr; } }
</style>
