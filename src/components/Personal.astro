---
import site from '../data/site.json';

// Brand marks for the linked cards — faded watermark + accent on hover, so it's
// obvious each card is clickable and where it goes.
const BRANDS: Record<string, { name: string; color: string; path: string }> = {
  linkedin: {
    name: 'LinkedIn', color: '#0A66C2',
    path: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z',
  },
  facebook: {
    name: 'Facebook', color: '#1877F2',
    path: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z',
  },
  instagram: {
    name: 'Instagram', color: '#E4405F',
    path: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z',
  },
  chess: {
    name: 'Chess.com', color: '#81B64C',
    path: 'M4 4h7v7H4zM13 13h7v7h-7zM13 4h7v7h-7zM4 13h7v7H4z',
  },
};
const brandOf = (href?: string) => {
  if (!href) return null;
  if (href.includes('linkedin')) return BRANDS.linkedin;
  if (href.includes('facebook')) return BRANDS.facebook;
  if (href.includes('instagram')) return BRANDS.instagram;
  if (href.includes('chess.com')) return BRANDS.chess;
  return null;
};
---
<section class="personal" id="offclock">
  <div class="wrap">
    <span class="kicker">Off the clock</span>
    <h2>The rest of it</h2>
    <div class="prow">
      {site.personal.map((c) => {
        const Tag = c.href ? 'a' : 'div';
        const brand = brandOf(c.href);
        const attrs = c.href ? { href: c.href, target: '_blank', rel: 'noopener' } : {};
        return (
          <Tag class={`c${c.href ? ' link' : ''}`} style={brand ? `--brand:${brand.color}` : undefined} {...attrs}>
            {brand && (
              <svg class="brandmark" viewBox="0 0 24 24" aria-hidden="true"><path d={brand.path} /></svg>
            )}
            <h3>{c.title}{c.href && <span class="ext"> ↗</span>}</h3>
            <p>{c.blurb}</p>
            {brand && <span class="golabel">Open on {brand.name}</span>}
          </Tag>
        );
      })}
    </div>
  </div>
</section>

<style>
  .personal { background: var(--blue-50); }
  .personal .kicker { color: var(--blue-s); }
  .personal h2 { margin-top: 12px; font-size: 29px; }
  .prow { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 28px; }
  .prow .c {
    position: relative; overflow: hidden;
    background: #fff; border: 1px solid var(--line); border-radius: 14px; padding: 18px; text-align: center;
  }
  .prow .c h3 { font-size: 16px; margin-bottom: 4px; }
  .prow .c p { font-size: 13px; color: var(--muted); }

  a.c.link {
    text-decoration: none; color: inherit; display: block;
    transition: transform .14s ease, box-shadow .14s ease, border-color .14s ease;
  }
  a.c.link:hover { transform: translateY(-3px); box-shadow: 0 12px 26px rgba(44, 31, 14, .12); border-color: var(--brand); }
  .ext { color: var(--brand); font-size: 12px; }

  .brandmark {
    position: absolute; right: -8px; bottom: -8px; width: 64px; height: 64px;
    fill: var(--ink); opacity: .06; transition: opacity .15s ease, fill .15s ease;
    pointer-events: none;
  }
  a.c.link:hover .brandmark { opacity: .18; fill: var(--brand); }

  .golabel {
    display: inline-block; margin-top: 9px; font-size: 11px; font-weight: 600; letter-spacing: .02em;
    color: var(--brand); opacity: .75; transition: opacity .15s ease;
  }
  a.c.link:hover .golabel { opacity: 1; }

  @media (max-width: 820px) { .prow { grid-template-columns: 1fr 1fr; } }
</style>
