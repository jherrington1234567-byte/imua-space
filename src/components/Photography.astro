---
import Gallery from './Gallery.astro';
import photog from '../data/photography.json';
---
<section class="photog" id="photography">
  <div class="wrap">
    <span class="kicker">Photography</span>
    <h2>I'm good at a lot</h2>
    <p class="lead">An eye that goes from the missile field to the networking floor — dogs, family, flight, and color. The best are up top; load more to wander the rest.</p>
    <Gallery images={photog.images} initial={20} cols={4} aspect="4/5" accent="pink" />
  </div>
</section>

<style>
  .photog { background: var(--pink-50); }
  .photog .kicker { color: var(--pink-s); }
  .photog h2 { margin-top: 12px; font-size: 29px; }
</style>
