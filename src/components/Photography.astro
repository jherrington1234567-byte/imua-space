---
// Curated selection. Real frames swap in from /public/images/photog as they're retouched.
const frames = [
  { img: '/images/photog/aviation.webp', label: 'Aviation' },
  { img: null, label: 'Portrait' },
  { img: null, label: 'Street' },
  { img: '/images/photog/juno.webp', label: 'Juno' },
  { img: null, label: 'Stage' },
  { img: null, label: 'Service' },
  { img: null, label: 'Landscape' },
  { img: null, label: 'The office I built' },
];
---
<section class="photog" id="photography">
  <div class="wrap">
    <span class="kicker">Photography</span>
    <h2>I'm good at a lot</h2>
    <p class="lead">An eye that goes from the missile field to the networking floor. A selection — the full gallery curates from 130+ frames.</p>
    <div class="pgrid">
      {frames.map((f) => (
        <div class="p">
          {f.img
            ? <img src={f.img} alt={f.label} loading="lazy" onerror={`this.parentElement.textContent='${f.label}'`} />
            : f.label}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .photog { background: var(--pink-50); }
  .photog .kicker { color: var(--pink-s); }
  .photog h2 { margin-top: 12px; font-size: 29px; }
  .pgrid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-top: 26px; }
  .pgrid .p {
    aspect-ratio: 4/5; border-radius: 12px; overflow: hidden; background: #f6d9e4;
    display: flex; align-items: center; justify-content: center;
    color: #c98ba6; font-size: 11px; text-align: center;
  }
  .pgrid .p img { width: 100%; height: 100%; object-fit: cover; }

  @media (max-width: 820px) { .pgrid { grid-template-columns: 1fr 1fr; } }
</style>
