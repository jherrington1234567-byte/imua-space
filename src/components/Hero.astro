---
/* ============================================================
   IMUA.SPACE — HERO
   Left: who I am + the promise, with the primary routes out
         (Substack, the book, About, LinkedIn).
   Right: the book "cover" — The Values Project — links to the book.
   Link targets live in src/data/site.json.
   ============================================================ */
import site from '../data/site.json';
---
<header class="hero" id="top">
  <div class="wrap inner">
    <div class="copy">
      <p class="kicker eyebrow">imua · to move forward</p>
      <h1>Come in <span class="em">from the storm.</span></h1>
      <p class="promise">Guarantees, not guesses. A check, not a maybe. I do what I say and say what I'll do — <b>maybe more, never less.</b></p>
      <p class="lede">A harbor for the educated and the driven in a world of maybes — a book written as it happens, a body of work built by hand, and a life behind both.</p>

      <div class="chips">
        <span class="chip p">Court of the Table 2026</span>
        <span class="chip b">NAIFA National AI Task Force</span>
        <span class="chip p">U.S. Air Force</span>
      </div>

      <div class="ctas">
        <a class="cta" href={site.substackUrl} target="_blank" rel="noopener">Read on Substack →</a>
        <a class="cta ghost" href="/#work">See the work →</a>
        <a class="cta ghost" href="/about/">About →</a>
        <a class="cta ghost" href={site.linkedinUrl} target="_blank" rel="noopener">LinkedIn →</a>
      </div>
    </div>

    <a class="cover" href={site.bookUrl} aria-label="The Values Project — read the book">
      <div class="cover-inner">
        <span class="cover-eyebrow">A multi-volume series</span>
        <img class="cover-logo" src="/brand/imua-logo.png" alt="IMUA" width="380" height="157" />
        <span class="cover-title">The Values Project</span>
        <span class="cover-author">Joshua Herrington</span>
        <span class="cover-rule"></span>
        <span class="cover-cta">Open the book →</span>
      </div>
    </a>
  </div>
</header>

<style>
  .hero { background: var(--cream); padding-top: clamp(40px, 6vh, 72px); padding-bottom: clamp(44px, 6vh, 72px); }
  .inner {
    display: grid; grid-template-columns: 1.15fr .85fr; gap: clamp(28px, 5vw, 64px);
    align-items: center;
  }

  .hero .eyebrow { color: var(--ember); font-weight: 600; }
  .hero h1 { font-size: clamp(34px, 6vw, 56px); line-height: 1.02; letter-spacing: -.015em; margin-top: 14px; max-width: 15ch; }
  .hero h1 .em { color: var(--ember); }

  .promise {
    font-family: var(--serif); font-weight: 500; font-size: clamp(17px, 2.4vw, 22px);
    line-height: 1.35; margin-top: 18px; max-width: 42ch; color: var(--ink);
  }
  .promise b { color: var(--ember); font-weight: 700; }
  .lede { margin-top: 14px; max-width: 44ch; font-size: clamp(15px, 2vw, 18px); color: var(--muted); }

  .chips { display: flex; flex-wrap: wrap; gap: 9px; margin-top: 22px; }

  .ctas { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 26px; }
  .ctas .cta.ghost {
    background: transparent; color: var(--brown); border: 1px solid var(--line);
  }
  .ctas .cta.ghost:hover { background: #fff; border-color: var(--brown2); }

  /* the book "cover" */
  .cover {
    display: block; text-decoration: none; justify-self: center;
    width: min(340px, 78vw); aspect-ratio: 5 / 7;
    border-radius: 6px; overflow: hidden;
    background: linear-gradient(160deg, #24190b 0%, #2c1f0e 55%, #3a2c17 100%);
    border: 1px solid #4a3a22;
    box-shadow:
      0 1px 0 rgba(255,255,255,.05) inset,
      -14px 0 22px -18px rgba(0,0,0,.6) inset, /* spine shadow */
      0 26px 60px -22px rgba(43, 32, 22, .7);
    transition: transform .25s ease, box-shadow .25s ease;
  }
  .cover:hover {
    transform: translateY(-4px) rotate(-.4deg);
    box-shadow: 0 34px 72px -24px rgba(43, 32, 22, .78);
  }
  .cover:focus-visible { outline: 2px solid var(--ember); outline-offset: 4px; }
  .cover-inner {
    height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; padding: 40px 26px; gap: 4px;
    border: 1px solid rgba(192,99,44,.28); border-radius: 4px; margin: 12px;
  }
  .cover-eyebrow {
    font-size: 10px; letter-spacing: .34em; text-transform: uppercase;
    color: rgba(237,228,216,.5); margin-bottom: 10px;
  }
  .cover-logo { width: clamp(150px, 46%, 220px); height: auto; opacity: .96; }
  .cover-title {
    font-family: var(--serif); font-size: clamp(15px, 2.4vw, 19px); font-weight: 500;
    letter-spacing: .26em; text-transform: uppercase; color: #c4a16e; margin-top: 18px;
  }
  .cover-author {
    font-family: var(--serif); font-size: 12px; letter-spacing: .2em; text-transform: uppercase;
    color: rgba(237,228,216,.5); margin-top: 8px;
  }
  .cover-rule {
    width: 90px; height: 1px; margin: 20px 0 16px;
    background: linear-gradient(to right, transparent, var(--ember), transparent);
  }
  .cover-cta { font-size: 12.5px; letter-spacing: .08em; color: #d9a06a; }

  @media (max-width: 780px) {
    .inner { grid-template-columns: 1fr; }
    .cover { order: -1; margin-bottom: 6px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cover { transition: none; }
  }
</style>
