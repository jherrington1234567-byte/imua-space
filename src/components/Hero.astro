---
/* ============================================================
   IMUA.SPACE — HERO : THE AUDIENCE LENS
   Click 1: pick a lens (Adventurer / Partner / Talent Scout)
            -> hero reframes with value + tailored routes
   Click 2: tap a route -> smooth-scroll to that section.

   EDIT HERE — the four lenses (single editable config array):
     key   : stable id used for state
     name  : the lens row title
     sub   : identity sub-line
     blurb : one-line description shown in the row
     acc   : role accent — 'rose' | 'blue' | 'terra' | 'ink'
     wide  : true => rendered as the full-width banner
     eyebrow : panel label
     value : the reframe (wrap one phrase in <b>..</b> to accent)
     routes  : doors {label, desc, href} into real section ids
   Real section ids: #mission #work #writing #about #record
                     #photography #offclock #gallery #connect
   ============================================================ */
const AUDIENCES = [
  {
    key: 'adventurer', name: 'Adventurer', sub: 'Refuge from the storm', acc: 'rose',
    blurb: 'An educated, values-driven individual finding success and seeking harbor.',
    eyebrow: 'For adventurers',
    value: "Read the book. Discover me. Decide if I'm <b>worthy of discovering you.</b>",
    routes: [
      { label: 'The book', desc: 'IMUA — the values project', href: '#writing' },
      { label: 'Photography', desc: 'The life behind the work', href: '#photography' },
    ],
  },
  {
    key: 'partner', name: 'Partner', sub: 'an advisor with shared values', acc: 'blue',
    blurb: 'You love the people who count on you the way I do — same standard, same fire.',
    eyebrow: 'For partners',
    value: 'Spend time here, see how I work and what I value, and you may find yourself <b>coveting the partnership.</b>',
    routes: [
      { label: 'Advisor tools', desc: 'PPVA Planner & the full lab', href: '#work' },
      { label: 'The book', desc: 'IMUA — the values project', href: '#writing' },
      { label: 'Photography', desc: 'The personal stuff', href: '#photography' },
      { label: 'MDRT — find yourself', desc: 'Find your photo from the floor', href: '#gallery' },
    ],
  },
  {
    key: 'scout', name: 'Talent Scout', sub: 'capital · leadership', acc: 'terra',
    blurb: 'You want someone who makes advisors better at serving the people who count on them.',
    eyebrow: 'For talent scouts',
    value: "That's the build — <b>a sales-leadership OS, pipeline, and process,</b> shipped and running. Bring the capital or the keys; I bring the system.",
    routes: [
      { label: 'The tool shed', desc: 'Sales-leadership OS · pipeline · process', href: '#work' },
      { label: 'The book', desc: 'IMUA — the values project', href: '#writing' },
      { label: 'MDRT — find yourself', desc: 'Find your photo from the floor', href: '#gallery' },
      { label: 'Photography', desc: 'The personal stuff', href: '#photography' },
    ],
  },
  {
    key: 'everything', name: 'The Hive', sub: "wired the way I'm wired",
    acc: 'ink', wide: true,
    blurb: "The restless, pattern-hungry, can't-put-it-down minds — wired the way I'm wired.",
    eyebrow: 'For the hive',
    value: "You don't want to be me — you're already wired like me. Same restless, pattern-hungry brain that can't leave a good problem alone. <b>Here's the whole hive</b> — every tool, every chapter, every frame.",
    routes: [
      { label: 'The work', desc: 'Guarantees, not guesses', href: '#mission' },
      { label: 'The Build Lab', desc: 'Working tools, live', href: '#work' },
      { label: 'The record', desc: 'Credentials & speaking', href: '#record' },
      { label: 'The becoming', desc: 'The story & throughline', href: '#about' },
      { label: 'The book', desc: 'IMUA — the values project', href: '#writing' },
      { label: 'Photography', desc: 'Dogs, flight, family, color', href: '#photography' },
      { label: 'MDRT — find yourself', desc: 'Find your photo from the floor', href: '#gallery' },
      { label: 'Off the clock', desc: 'The rest of it', href: '#offclock' },
      { label: 'Connect', desc: 'News from the Desk', href: '#connect' },
    ],
  },
];

const lenses = AUDIENCES.filter((a) => !a.wide);
const banner = AUDIENCES.find((a) => a.wide);

const ARROW =
  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>';
---
<header class="hero" id="top">
  <div class="wrap">
    <p class="kicker eyebrow">imua · to move forward</p>
    <h1>Come in <span class="em">from the storm.</span></h1>
    <p class="promise">Guarantees, not guesses. A check, not a maybe. I do what I say and say what I'll do — <b>maybe more, never less.</b></p>
    <p class="lede">A harbor for the educated and the driven in a world of maybes — a book, a stack of working tools, and a life behind both. Tell me how you wandered in.</p>

    <div class="chips">
      <span class="chip p">Court of the Table 2026</span>
      <span class="chip b">NAIFA National AI Task Force</span>
      <span class="chip p">U.S. Air Force</span>
    </div>

    <div class="lens">
      <div class="lens-q">Who wandered in?</div>
      <div class="lens-sub"><b>Pick a lens</b> to see your path &nbsp;·&nbsp; then tap a route to go in</div>

      <div class="picker">
        {lenses.map((a) => (
          <button
            class={`aud acc-${a.acc}`}
            type="button"
            data-aud={a.key}
            aria-pressed="false"
            aria-controls="lens-panel"
          >
            <span class="a-left">
              <span class="a-name">{a.name}</span>
              <span class="a-sub">{a.sub}</span>
              <span class="a-blurb">{a.blurb}</span>
            </span>
            <span class="a-go">See your path <Fragment set:html={ARROW} /></span>
          </button>
        ))}
      </div>

      {banner && (
        <div class="banner-wrap">
          <button
            class={`aud aud-wide acc-${banner.acc}`}
            type="button"
            data-aud={banner.key}
            aria-pressed="false"
            aria-controls="lens-panel"
          >
            <span class="a-left">
              <span class="a-name">{banner.name}</span>
              <span class="a-sub">{banner.sub}</span>
              <span class="a-blurb">{banner.blurb}</span>
            </span>
            <span class="a-go">Enter the hive <Fragment set:html={ARROW} /></span>
          </button>
        </div>
      )}

      <div class="panel" id="lens-panel" aria-live="polite">
        <div class="wrap-inner"><div class="pad" id="lens-panel-body"></div></div>
      </div>
    </div>
  </div>

  <div class="toast" id="lens-toast" role="status" aria-live="polite"></div>

  <script is:inline define:vars={{ AUDIENCES, ARROW }}>
    const panel = document.getElementById('lens-panel');
    const panelBody = document.getElementById('lens-panel-body');
    const triggers = Array.from(document.querySelectorAll('.aud'));
    let active = null;

    function render(a) {
      panelBody.innerHTML = `
        <div class="p-eyebrow">${a.eyebrow}</div>
        <div class="p-value">${a.value}</div>
        <div class="routes">
          ${a.routes
            .map(
              (r) =>
                `<a class="route" href="${r.href}"><span class="r-label">${r.label} ${ARROW}</span><span class="r-desc">${r.desc}</span></a>`,
            )
            .join('')}
        </div>`;
    }

    function sync() {
      triggers.forEach((b) =>
        b.setAttribute('aria-pressed', b.dataset.aud === active ? 'true' : 'false'),
      );
    }

    function close() {
      panel.classList.remove('open', 'acc-rose', 'acc-blue', 'acc-terra', 'acc-ink');
      panelBody.innerHTML = '';
    }

    function select(key) {
      const a = AUDIENCES.find((x) => x.key === key);
      if (!a) return;
      // re-tapping the active lens closes it
      if (active === key) {
        active = null;
        close();
        sync();
        return;
      }
      active = key;
      sync();
      render(a);
      panel.className = 'panel open acc-' + a.acc;
    }

    triggers.forEach((b) => b.addEventListener('click', () => select(b.dataset.aud)));

    // Click 2 — route taps: anchor scrolls; toast confirms.
    let tt;
    const toastEl = document.getElementById('lens-toast');
    panel.addEventListener('click', (e) => {
      const r = e.target.closest('.route');
      if (!r) return;
      const label = r.querySelector('.r-label').textContent.trim();
      toastEl.textContent = '→ ' + label;
      toastEl.classList.add('show');
      clearTimeout(tt);
      tt = setTimeout(() => toastEl.classList.remove('show'), 1700);
    });
  </script>
</header>

<style>
  .hero { background: var(--cream); padding-top: clamp(40px, 6vh, 64px); padding-bottom: clamp(44px, 6vh, 64px); }
  .hero .eyebrow { color: var(--ember); font-weight: 600; }
  .hero h1 { font-size: clamp(34px, 8vw, 60px); line-height: 1.02; letter-spacing: -.015em; margin-top: 14px; max-width: 15ch; }
  .hero h1 .em { color: var(--ember); }

  .promise {
    font-family: var(--serif); font-weight: 500; font-size: clamp(17px, 2.4vw, 22px);
    line-height: 1.35; margin-top: 18px; max-width: 40ch; color: var(--ink);
  }
  .promise b { color: var(--ember); font-weight: 700; }
  .lede { margin-top: 14px; max-width: 42ch; font-size: clamp(15px, 2vw, 18px); color: var(--muted); }

  .chips { display: flex; flex-wrap: wrap; gap: 9px; margin-top: 22px; }

  /* lens picker */
  .lens { margin-top: 38px; }
  .lens-q { font-family: var(--serif); font-weight: 600; color: var(--brown); font-size: clamp(20px, 3vw, 26px); }
  .lens-sub { font-size: 13.5px; color: var(--muted); margin-top: 6px; }
  .lens-sub b { color: var(--ink); font-weight: 600; }

  .picker { display: grid; grid-template-columns: 1fr; gap: 12px; margin-top: 18px; }

  .aud {
    text-align: left; background: #fff; border: 1px solid var(--line); border-radius: var(--radius);
    padding: 16px 18px; cursor: pointer; font: inherit; color: var(--ink);
    border-left-width: 5px; width: 100%;
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
  }
  .aud:hover { transform: translateY(-2px); box-shadow: 0 14px 30px -18px rgba(43, 32, 22, .45); }
  .aud:focus-visible { outline: 2px solid var(--ink); outline-offset: 3px; }
  .a-left { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
  .a-name { font-family: var(--serif); font-weight: 600; font-size: 19px; color: var(--brown); }
  .a-sub { font-size: 13px; color: var(--muted); }
  .a-blurb { font-size: 13px; color: var(--muted); max-width: 54ch; line-height: 1.4; margin-top: 2px; }
  .a-go {
    flex: 0 0 auto; white-space: nowrap; font-size: 12.5px; font-weight: 600;
    display: inline-flex; align-items: center; gap: 6px; color: var(--muted);
  }
  .a-go :global(svg) { width: 13px; height: 13px; }
  .aud[aria-pressed='true'] .a-go { color: var(--ink); }

  .banner-wrap { margin-top: 12px; }
  .aud-wide { background: var(--cream); }

  /* role accents */
  .aud.acc-rose { border-left-color: var(--pink-s); }
  .aud.acc-blue { border-left-color: var(--blue-s); }
  .aud.acc-terra { border-left-color: var(--ember); }
  .aud.acc-ink { border-left-color: var(--brown); }
  .aud.acc-rose[aria-pressed='true'] { border-color: var(--pink-s); }
  .aud.acc-blue[aria-pressed='true'] { border-color: var(--blue-s); }
  .aud.acc-terra[aria-pressed='true'] { border-color: var(--ember); }
  .aud.acc-ink[aria-pressed='true'] { border-color: var(--brown); }
  .aud[aria-pressed='true'] { box-shadow: 0 16px 38px -16px rgba(43, 32, 22, .5); }

  /* tailored panel */
  .panel {
    margin-top: 16px; border-radius: 16px; overflow: hidden;
    border: 1px solid var(--line); background: #fff;
    display: grid; grid-template-rows: 0fr; opacity: 0;
    transition: grid-template-rows .34s ease, opacity .3s ease;
  }
  .panel.open { grid-template-rows: 1fr; opacity: 1; }
  .panel .wrap-inner { overflow: hidden; min-height: 0; }
  .panel .pad { padding: 22px; }
  .panel :global(.p-eyebrow) { font-weight: 700; font-size: 12px; letter-spacing: .18em; text-transform: uppercase; }
  .panel :global(.p-value) {
    font-family: var(--serif); font-weight: 500; font-size: clamp(18px, 2.6vw, 24px);
    line-height: 1.3; margin-top: 10px; max-width: 48ch; color: var(--brown);
  }
  .panel :global(.p-value b) { font-weight: 700; }

  .panel :global(.routes) {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 11px; margin-top: 20px;
  }
  .panel :global(.route) {
    display: flex; flex-direction: column; gap: 3px; text-decoration: none; cursor: pointer;
    border: 1px solid var(--line); border-radius: 12px; padding: 14px 15px; color: var(--ink);
    background: var(--cream); transition: transform .15s ease, box-shadow .2s ease, border-color .2s ease;
  }
  .panel :global(.route:hover) { transform: translateY(-2px); box-shadow: 0 12px 26px -16px rgba(43, 32, 22, .45); }
  .panel :global(.route:focus-visible) { outline: 2px solid var(--ink); outline-offset: 2px; }
  .panel :global(.r-label) { font-weight: 600; font-size: 15px; display: flex; align-items: center; gap: 6px; color: var(--ink); }
  .panel :global(.r-label svg) { width: 14px; height: 14px; }
  .panel :global(.r-desc) { font-size: 12.5px; color: var(--muted); }

  /* per-audience accent applied to the open panel */
  .panel.acc-rose :global(.p-eyebrow), .panel.acc-rose :global(.p-value b), .panel.acc-rose :global(.r-label svg) { color: var(--pink-s); }
  .panel.acc-rose :global(.route:hover) { border-color: var(--pink-s); }
  .panel.acc-blue :global(.p-eyebrow), .panel.acc-blue :global(.p-value b), .panel.acc-blue :global(.r-label svg) { color: var(--blue-s); }
  .panel.acc-blue :global(.route:hover) { border-color: var(--blue-s); }
  .panel.acc-terra :global(.p-eyebrow), .panel.acc-terra :global(.p-value b), .panel.acc-terra :global(.r-label svg) { color: var(--ember); }
  .panel.acc-terra :global(.route:hover) { border-color: var(--ember); }
  .panel.acc-ink :global(.p-eyebrow), .panel.acc-ink :global(.p-value b), .panel.acc-ink :global(.r-label svg) { color: var(--brown); }
  .panel.acc-ink :global(.route:hover) { border-color: var(--brown); }

  /* toast */
  .toast {
    position: fixed; left: 50%; bottom: 26px; transform: translateX(-50%) translateY(18px);
    background: var(--brown); color: var(--cream); border: 1px solid var(--ember);
    padding: 12px 18px; border-radius: 10px; font-size: 14px; font-weight: 500;
    opacity: 0; pointer-events: none; transition: opacity .25s ease, transform .25s ease; z-index: 60;
  }
  .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

  @media (prefers-reduced-motion: reduce) {
    .aud, .panel, .panel :global(.route), .toast { transition: none; }
  }
</style>
