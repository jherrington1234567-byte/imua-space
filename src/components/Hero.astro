---
import site from '../data/site.json';
const h = site.hero;
---
<header class="hero" id="top">
  <div class="wrap">
    <div>
      <span class="kicker">{h.kicker}</span>
      <h1>{h.headlineLead} <span class="em">{h.headlineEm}</span>{h.headlineTail}</h1>
      <div class="sub">{h.sub}</div>
      <div class="chips">
        {h.chips.map((c) => <span class={`chip ${c.style}`}>{c.label}</span>)}
      </div>
      <a class="cta" href={h.ctaHref}>{h.ctaLabel}</a>
    </div>
    <div class="heroframe">
      <img src={h.image} alt={h.imageAlt} width="640" height="800" loading="eager" />
      <span class="cap">{h.caption}</span>
    </div>
  </div>
</header>

<style>
  .hero { background: var(--cream); padding-top: 64px; padding-bottom: 56px; }
  .hero .wrap {
    display: grid; grid-template-columns: 1.1fr 1fr; gap: 42px; align-items: center;
  }
  .hero .kicker { color: var(--ember); }
  .hero h1 { font-size: 42px; margin-top: 14px; }
  .hero h1 .em { color: var(--ember); }
  .hero .sub { margin-top: 18px; color: var(--muted); font-size: 16px; }
  .chips { display: flex; flex-wrap: wrap; gap: 9px; margin-top: 24px; }
  .cta { margin-top: 24px; }

  .heroframe {
    border-radius: 16px; overflow: hidden; border: 1px solid var(--line);
    box-shadow: 0 14px 40px rgba(44, 31, 14, .14); position: relative; background: #26201a;
  }
  .heroframe img { width: 100%; display: block; aspect-ratio: 4/5; object-fit: cover; }
  .heroframe .cap {
    position: absolute; left: 12px; bottom: 10px; font-size: 12px; color: #fff;
    background: rgba(20, 16, 10, .6); padding: 4px 10px; border-radius: 7px;
  }

  @media (max-width: 820px) {
    .hero .wrap { grid-template-columns: 1fr; }
    .hero h1 { font-size: 34px; }
  }
</style>
