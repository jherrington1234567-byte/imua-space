---
// Reusable photo gallery: shows `initial` thumbnails, "Load more" reveals the rest,
// click any thumb for a lightbox. Optional filter pills. Used by Photography + MDRT.
interface Img { thumb: string; full: string; caption?: string; key?: string }
interface Filter { key: string; label: string }
interface Props {
  images: Img[];
  initial?: number;
  cols?: number;
  aspect?: string;        // CSS aspect-ratio for tiles, e.g. "1" or "4/5"
  accent?: 'pink' | 'blue';
  filters?: Filter[];
}
const { images, initial = 20, cols = 5, aspect = '1', accent = 'pink', filters } = Astro.props;
---
<div class="gallery-root" data-initial={initial} data-accent={accent} style={`--cols:${cols};--tile-aspect:${aspect}`}>
  {filters && filters.length > 0 && (
    <div class="filterrow" role="tablist">
      {filters.map((f, i) => (
        <button class={`fpill${i === 0 ? ' active' : ''}`} data-filter={f.key}>{f.label}</button>
      ))}
    </div>
  )}

  <div class="ggrid">
    {images.map((im, i) => (
      <button class="gtile" data-i={i} data-key={im.key ?? ''} data-full={im.full} data-cap={im.caption ?? ''} aria-label={im.caption ?? 'Open photo'}>
        <img src={im.thumb} alt={im.caption ?? ''} loading="lazy" width="400" height="400" />
        {im.caption && <span class="gcap">{im.caption}</span>}
      </button>
    ))}
  </div>

  <button class="loadmore" type="button">Load more</button>

  <div class="lightbox" hidden>
    <button class="lb-close" aria-label="Close">×</button>
    <button class="lb-prev" aria-label="Previous">‹</button>
    <figure><img src="" alt="" /><figcaption></figcaption></figure>
    <button class="lb-next" aria-label="Next">›</button>
  </div>
</div>

<style>
  .gallery-root { margin-top: 22px; }
  .filterrow { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 18px; }
  .fpill {
    font-size: 12px; background: #fff; border: 1px solid #efd7e1; color: var(--pink-s);
    border-radius: 999px; padding: 5px 12px; cursor: pointer;
  }
  .fpill.active { background: var(--pink-s); color: #fff; border-color: var(--pink-s); }
  .gallery-root[data-accent='blue'] .fpill { border-color: #d2e1f3; color: var(--blue-s); }
  .gallery-root[data-accent='blue'] .fpill.active { background: var(--blue-s); border-color: var(--blue-s); color: #fff; }

  .ggrid { display: grid; grid-template-columns: repeat(var(--cols), 1fr); gap: 8px; }
  .gtile {
    position: relative; aspect-ratio: var(--tile-aspect); border-radius: 10px; overflow: hidden;
    border: none; padding: 0; background: #f0e7d9; cursor: pointer;
  }
  .gtile img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .25s ease; }
  .gtile:hover img { transform: scale(1.04); }
  .gcap {
    position: absolute; left: 0; right: 0; bottom: 0; padding: 14px 8px 6px;
    font-size: 11px; color: #fff; text-align: left; opacity: 0;
    background: linear-gradient(to top, rgba(20,16,10,.7), transparent); transition: opacity .2s ease;
  }
  .gtile:hover .gcap { opacity: 1; }

  .loadmore {
    display: block; margin: 22px auto 0; padding: 11px 22px; border-radius: 10px;
    border: 1px solid var(--line); background: #fff; color: var(--brown);
    font-size: 14px; cursor: pointer; font-family: var(--sans);
  }
  .loadmore:hover { background: var(--brown); color: var(--cream); border-color: var(--brown); }
  .loadmore[hidden] { display: none; }

  .lightbox {
    position: fixed; inset: 0; z-index: 50; background: rgba(20, 16, 10, .92);
    display: flex; align-items: center; justify-content: center;
  }
  .lightbox[hidden] { display: none; }
  .lightbox figure { margin: 0; max-width: 90vw; max-height: 88vh; text-align: center; }
  .lightbox img { max-width: 90vw; max-height: 82vh; border-radius: 8px; }
  .lightbox figcaption { color: #e9ddc9; font-size: 13px; margin-top: 10px; font-family: var(--serif); }
  .lightbox button {
    position: absolute; background: rgba(255, 255, 255, .12); color: #fff; border: none;
    cursor: pointer; font-size: 28px; width: 48px; height: 48px; border-radius: 50%;
  }
  .lb-close { top: 20px; right: 24px; }
  .lb-prev { left: 18px; }
  .lb-next { right: 18px; }

  @media (max-width: 820px) {
    .ggrid { grid-template-columns: repeat(min(var(--cols), 4), 1fr); }
  }
  @media (max-width: 520px) {
    .ggrid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.gallery-root').forEach((root) => {
    const initial = parseInt(root.dataset.initial || '20', 10);
    const tiles = Array.from(root.querySelectorAll<HTMLElement>('.gtile'));
    const pills = Array.from(root.querySelectorAll<HTMLButtonElement>('.fpill'));
    const loadmore = root.querySelector<HTMLButtonElement>('.loadmore');
    let filter = 'All';
    let shown = initial;

    const matching = () => tiles.filter((t) => filter === 'All' || t.dataset.key === filter);

    const render = () => {
      const match = matching();
      tiles.forEach((t) => (t.style.display = 'none'));
      match.slice(0, shown).forEach((t) => (t.style.display = ''));
      if (loadmore) loadmore.hidden = match.length <= shown;
    };

    pills.forEach((p) =>
      p.addEventListener('click', () => {
        pills.forEach((x) => x.classList.remove('active'));
        p.classList.add('active');
        filter = p.dataset.filter || 'All';
        shown = initial;
        render();
      }),
    );
    loadmore?.addEventListener('click', () => { shown += initial; render(); });

    // lightbox over the currently-visible tiles
    const lb = root.querySelector<HTMLElement>('.lightbox');
    const lbImg = lb?.querySelector('img') as HTMLImageElement | null;
    const lbCap = lb?.querySelector('figcaption') as HTMLElement | null;
    if (lb && lbImg) {
      let idx = 0;
      const visible = () => tiles.filter((t) => t.style.display !== 'none');
      const open = (i: number) => {
        const list = visible();
        if (!list.length) return;
        idx = (i + list.length) % list.length;
        const t = list[idx];
        lbImg.src = t.dataset.full || '';
        if (lbCap) lbCap.textContent = t.dataset.cap || '';
        lb.hidden = false;
      };
      root.querySelector('.ggrid')?.addEventListener('click', (e) => {
        const t = (e.target as HTMLElement).closest('.gtile') as HTMLElement | null;
        if (t) open(visible().indexOf(t));
      });
      lb.querySelector('.lb-close')?.addEventListener('click', () => (lb.hidden = true));
      lb.querySelector('.lb-next')?.addEventListener('click', () => open(idx + 1));
      lb.querySelector('.lb-prev')?.addEventListener('click', () => open(idx - 1));
      lb.addEventListener('click', (e) => { if (e.target === lb) lb.hidden = true; });
      document.addEventListener('keydown', (e) => {
        if (lb.hidden) return;
        if (e.key === 'Escape') lb.hidden = true;
        if (e.key === 'ArrowRight') open(idx + 1);
        if (e.key === 'ArrowLeft') open(idx - 1);
      });
    }

    render();
  });
</script>
