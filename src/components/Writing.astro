---
import { getCollection } from 'astro:content';
import site from '../data/site.json';

const vols = [
  { n: 'Prologue', name: 'ORIGIN', sub: "I Don't Love You Right Now", color: 'var(--vol-origin)', route: '/origin/' },
  { n: 'Volume I', name: 'IMUA', sub: 'Dispatches from the Path Forward', color: 'var(--vol-imua)', route: '/imua/' },
  { n: 'Volume II', name: 'OHANA', sub: 'On Who You Build With', color: 'var(--vol-ohana)', route: '/ohana/' },
  { n: 'Volume III', name: 'PONO', sub: 'On Doing Right', color: 'var(--vol-pono)', route: '/pono/' },
  { n: 'Volume IV', name: 'ALOHA', sub: 'Presence as a Practice', color: 'var(--vol-aloha)', route: '/aloha/' },
  { n: 'Volume V', name: 'MAHALO', sub: 'Gratitude as Discipline', color: 'var(--vol-mahalo)', route: '/mahalo/' },
];

const featured = (await getCollection('essays', ({ data }) => data.featured && !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())[0];
---
<section class="writing" id="writing">
  <div class="wrap">
    <span class="kicker">The writing</span>
    <h2>IMUA — The Values Project</h2>
    <p class="lead">Six volumes. A field journal kept by a man still in the middle of becoming — available to read and to listen to.</p>

    <div class="vols">
      {vols.map((v) => (
        <a class="vol" style={`border-top-color:${v.color}`} href={v.route}>
          <div class="n">{v.n}</div>
          <div><h3>{v.name}</h3><div class="s">{v.sub}</div></div>
        </a>
      ))}
    </div>

    {featured && (
      <a class="featured" href={`/writing/${featured.slug}`}>
        <span class="flabel">News from the Desk</span>
        <h3>{featured.data.title}</h3>
        {featured.data.dek && <p>{featured.data.dek}</p>}
      </a>
    )}

    <blockquote class="quote">
      Identity is not something you find. It is something you build — in the dark, in the
      repetition, in the absence of validation.
      <cite>— IMUA, "Discipline Before Identity"</cite>
    </blockquote>

    <a class="becoming" href={site.substackUrl} target="_blank" rel="noopener">
      <span class="b-label">The sequel, in real time</span>
      <h3 class="b-title">Becoming<span class="b-flourish">the second book</span></h3>
      <p class="b-desc">
        News from the Desk — the reflections that will shape the sequel, written as it
        happens, not in hindsight. Read it as <em>becoming becomes.</em>
      </p>
      <span class="b-go">Follow @imuaspace on Substack →</span>
    </a>
  </div>
</section>

<style>
  /* THE BROWN BOOK SECTION (spine) */
  .writing { background: var(--brown); color: var(--cream); }
  .writing h2 { color: var(--cream); margin-top: 12px; font-size: 29px; }
  .writing .kicker { color: #d9a06a; }
  .writing .lead { color: #cdbfa9; }
  .vols { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-top: 28px; }
  .vol {
    background: var(--brown2); border-radius: 12px; padding: 18px; min-height: 120px;
    display: flex; flex-direction: column; justify-content: space-between;
    border-top: 4px solid; text-decoration: none; transition: transform .12s ease;
  }
  .vol:hover { transform: translateY(-2px); }
  .vol .n { font-size: 11px; color: #b9a98f; letter-spacing: 2px; text-transform: uppercase; }
  .vol h3 { font-size: 21px; color: var(--cream); margin-top: 6px; }
  .vol .s { font-size: 13px; color: #cdbfa9; }

  .featured {
    display: block; margin-top: 22px; padding: 20px; border-radius: 12px;
    background: rgba(255, 255, 255, .04); border: 1px solid #4a3a22; text-decoration: none;
  }
  .featured:hover { background: rgba(255, 255, 255, .07); }
  .flabel { font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: #d9a06a; }
  .featured h3 { color: var(--cream); font-size: 20px; margin-top: 6px; }
  .featured p { color: #cdbfa9; font-size: 14px; margin-top: 6px; }

  .quote {
    margin-top: 30px; border-left: 3px solid var(--ember); padding: 4px 0 4px 20px;
    font-family: var(--serif); font-size: 21px; color: var(--cream); max-width: 760px;
  }
  .quote cite {
    display: block; font-family: var(--sans); font-size: 13px; color: #b9a98f;
    font-style: normal; margin-top: 10px;
  }

  /* Becoming — the sequel, in real time. Echoes the Substack: near-black, white
     serif, gold italic flourish — a step into the publication. */
  .becoming {
    display: block; margin-top: 30px; padding: 38px 28px; border-radius: 14px;
    text-decoration: none; text-align: center;
    background:
      radial-gradient(130% 130% at 50% 0%, rgba(217, 160, 106, .12), transparent 58%),
      #15100b;
    border: 1px solid #3a2c1a;
    transition: transform .15s ease, box-shadow .25s ease, border-color .25s ease;
  }
  .becoming:hover {
    transform: translateY(-2px); border-color: #d9a06a;
    box-shadow: 0 26px 54px -24px rgba(0, 0, 0, .7);
  }
  .b-label {
    font-size: 11px; letter-spacing: .3em; text-transform: uppercase; color: #d9a06a;
  }
  .b-title {
    font-family: var(--serif); font-size: clamp(38px, 8vw, 60px); color: #fff;
    line-height: 1; margin-top: 14px; letter-spacing: .01em;
    display: flex; flex-direction: column; align-items: center; gap: 6px;
  }
  .b-flourish {
    font-size: clamp(17px, 3vw, 22px); font-style: italic; font-weight: 400;
    color: #d9a06a; letter-spacing: .01em;
  }
  .b-desc {
    color: #b9a98f; font-size: 15px; line-height: 1.65; max-width: 50ch;
    margin: 16px auto 0;
  }
  .b-desc em { color: #fff; font-style: italic; }
  .b-go {
    display: inline-block; margin-top: 22px; padding: 11px 20px; border-radius: 10px;
    background: var(--ember); color: #fff; font-weight: 600; font-size: 14.5px;
  }
  .becoming:hover .b-go { filter: brightness(1.08); }

  @media (max-width: 820px) { .vols { grid-template-columns: 1fr 1fr; } }
</style>
