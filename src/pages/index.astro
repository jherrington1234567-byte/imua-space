    Build Lab (the "tools" section, id="work") is intentionally hidden for now.
    Kept in the codebase so it can be restored later: uncomment the import above
    and this line. The component (BuildLab.astro) and its cards in
    src/content/buildlab/ are untouched.
  */}
  {/* <BuildLab /> */}
  <Writing />
  <Becoming />
  <Credentials />
  <Photography />
  <Personal />
  <MdrtGallery />
  <Connect />
</Base>
