---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import MissionScroll from '../components/MissionScroll.astro';
import MissionBand from '../components/MissionBand.astro';
import Thesis from '../components/Thesis.astro';
import Work from '../components/Work.astro';
// Build Lab (live tools showcase) stays hidden — replaced by the descriptive
// Work section below. Component + src/content/buildlab/ are kept for later.
// import BuildLab from '../components/BuildLab.astro';
import MdrtGallery from '../components/MdrtGallery.astro';
import Writing from '../components/Writing.astro';
import Becoming from '../components/Becoming.astro';
import Credentials from '../components/Credentials.astro';
import Photography from '../components/Photography.astro';
import Personal from '../components/Personal.astro';
import Connect from '../components/Connect.astro';
---
<Base>
  <Hero />
  <MissionScroll />
  <MissionBand />
  <Thesis />
  {/*
    The live Build Lab (interactive tool demos) stays hidden out of respect for
    a former employer's request. Work.astro replaces it: a descriptive account
    of what's been built + the skillset, with no live tool links. To restore the
    live demos later, uncomment the BuildLab import above and swap it back in.
  */}
  <Work />
  <Writing />
  <Becoming />
  <Credentials />
  <Photography />
  <Personal />
  <MdrtGallery />
  <Connect />
</Base>
